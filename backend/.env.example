# 数据库配置 (PostgreSQL - 存储应用数据)
# 支持异步连接 (postgresql+asyncpg://) 和同步连接 (postgresql://)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gsd_db_compare

# 加密密钥 (用于加密存储的数据库密码)
# 生成命令：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<your-32-byte-encryption-key>

# 日志配置
LOG_LEVEL=INFO

# SMTP 邮件通知配置 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
USE_TLS=true
SENDER_EMAIL=noreply@example.com
SENDER_NAME=DB Compare
